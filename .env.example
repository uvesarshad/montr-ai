# =============================================================================
# MontrAI — .env.example (fair-code / source-available, single-tenant core)
# =============================================================================
# Copy to .env.local and fill in the values. This file ships with ZERO real
# secrets — every credential below is an empty/placeholder value.
#
#   cp .env.example .env.local
#
# First run = one owner, one workspace, every feature unlocked. AI and per-
# platform OAuth are BYOK / BYO-app (you bring your own keys + register your
# own OAuth apps). Most keys are OPTIONAL — empty disables that feature.
#
# REQUIRED to boot: MongoDB, Postgres (pgvector), Redis, an auth secret, and a
# base URL. Everything else is opt-in.
#
# Generate a 32-byte (64-hex) encryption key with:
#   openssl rand -hex 32
#   # or:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Generate an auth secret with:
#   openssl rand -base64 32
# =============================================================================


# -----------------------------------------------------------------------------
# DB — MongoDB + Postgres/pgvector (REQUIRED to boot)
# -----------------------------------------------------------------------------
# Mongo must run as a single-node REPLICA SET (transactions are used). Postgres
# must have the pgvector extension (CREATE EXTENSION vector) — pg-client throws
# hard if neither DATABASE_URL nor POSTGRES_URL is set.
MONGODB_URI=mongodb://localhost:27017/montrai
MONGODB_DB_NAME=montrai
MONGODB_SERVER_SELECTION_TIMEOUT_MS=20000
# pgvector store — set DATABASE_URL *or* POSTGRES_URL (either satisfies the client):
DATABASE_URL=postgresql://postgres:password@localhost:5432/montrai
# POSTGRES_URL=postgresql://postgres:password@localhost:5432/montrai


# -----------------------------------------------------------------------------
# Redis — BullMQ queues + auth rate-limiter (REQUIRED; login fails CLOSED without it)
# -----------------------------------------------------------------------------
# The worker exits 1 if Redis is not configured, and login is denied when Redis
# is down (fail-closed rate limiter). Use REDIS_URL, or the worker-side parts.
REDIS_URL=redis://localhost:6379
# Worker-side alternative to REDIS_URL (leave unset if using REDIS_URL):
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
# REDIS_CONNECTION_STRING=


# -----------------------------------------------------------------------------
# App identity + auth secrets (REQUIRED — set a base URL and ONE auth secret)
# -----------------------------------------------------------------------------
# BetterAuth resolves the secret BETTER_AUTH_SECRET -> AUTH_SECRET -> NEXTAUTH_SECRET,
# and the base URL BETTER_AUTH_URL -> NEXTAUTH_URL -> NEXT_PUBLIC_APP_URL.
NODE_ENV=production
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:9002
BETTER_AUTH_URL=http://localhost:9002
NEXTAUTH_URL=http://localhost:9002
AUTH_URL=http://localhost:9002
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=CHANGE_ME
# Fallback secret names (only one is needed — keep them in sync if you set them):
# AUTH_SECRET=CHANGE_ME
# NEXTAUTH_SECRET=CHANGE_ME
# First-run owner (super-admin) — change before first boot:
NEXT_PUBLIC_SUPER_ADMIN_EMAIL=owner@example.com
SUPER_ADMIN_EMAIL=owner@example.com
# Seed/reset only — leave blank in normal operation:
SUPER_ADMIN_PASSWORD=
# Dangerous auth-reset guard — keep UNSET:
# RESET_AUTH_CONFIRM=


# -----------------------------------------------------------------------------
# Security — proxy trust, CSRF/CORS allow-list, rate limit, cron guard
# -----------------------------------------------------------------------------
# AUTH_TRUST_HOST is REQUIRED behind a reverse proxy (Nginx/CloudPanel), or
# BetterAuth rejects the proxied host.
AUTH_TRUST_HOST=true
TRUST_PROXY_DEPTH=1
ALLOWED_ORIGINS=http://localhost:9002
RATE_LIMIT_RPM=100
# Guards /api/cron/* + scheduled-task routes — generate with: openssl rand -hex 32
CRON_SECRET=CHANGE_ME
# Optional reCAPTCHA (leave blank to disable):
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# RECAPTCHA_SECRET_KEY=


# -----------------------------------------------------------------------------
# Encryption keys — all 64-hex (32 bytes); throw on first use if wrong length
# -----------------------------------------------------------------------------
# Generate each with: openssl rand -hex 32
# CRM/workflow credential encryption (throws if missing/not 64-hex when used):
WORKFLOW_ENCRYPTION_KEY=CHANGE_ME_64_HEX
# Social OAuth token encryption (throws if not 64-hex):
SOCIAL_TOKEN_ENCRYPTION_KEY=CHANGE_ME_64_HEX
# WhatsApp access-token encryption (64-hex):
ENCRYPTION_KEY=CHANGE_ME_64_HEX
# Marketing-email open/click token HMAC:
EMAIL_TRACKING_SECRET=CHANGE_ME


# -----------------------------------------------------------------------------
# AI — system BYOK keys (all OPTIONAL; empty = provider disabled)
# -----------------------------------------------------------------------------
# Set at least ONE of GEMINI/OPENAI/OPENROUTER (or a per-user BYOK key) before
# using AI Studio / agent / chatbot, or AI surfaces 500 with zero providers.
GEMINI_API_KEY=
# GOOGLE_AI_API_KEY=        # alias of GEMINI_API_KEY
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
SARVAM_API_KEY=
# SARVAM_BASE_URL=
MOONSHOT_API_KEY=
# MOONSHOT_BASE_URL=https://api.moonshot.ai/v1
ZAI_API_KEY=
# ZAI_BASE_URL=https://api.z.ai/api/paas/v4
# OpenAI-compatible long-tail providers (optional):
MISTRAL_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
GROQ_API_KEY=
PERPLEXITY_API_KEY=
COHERE_API_KEY=
# Optional model override:
# OPENAI_MODEL=

# --- AI media / voice provider keys (all OPTIONAL; empty = feature disabled) ---
RUNWAY_API_KEY=
PIKA_API_KEY=
LUMA_API_KEY=
KLING_API_KEY=
SEEDANCE_API_KEY=
REPLICATE_API_KEY=
IDEOGRAM_API_KEY=
ELEVENLABS_API_KEY=
DID_API_KEY=
HEYGEN_API_KEY=
FAL_API_KEY=
DEEPGRAM_API_KEY=
VOICE_REALTIME_API_KEY=
# Optional base-URL overrides:
# RUNWAY_BASE_URL=
# ELEVENLABS_BASE_URL=
# IDEOGRAM_BASE_URL=
# DID_BASE_URL=
# HEYGEN_BASE_URL=


# -----------------------------------------------------------------------------
# Feature keys — scraping / stock-media / link-shortening (all OPTIONAL)
# -----------------------------------------------------------------------------
APIFY_API_TOKEN=
JINA_API_KEY=
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=
PIXABAY_API_KEY=
DUB_API_KEY=
SHORTIO_API_KEY=
# SHORTIO_DOMAIN=


# -----------------------------------------------------------------------------
# Storage — S3-compatible object storage (AWS S3, Wasabi, MinIO, OCI)
# -----------------------------------------------------------------------------
# Switch: aws | wasabi (default aws). There is NO working local-disk provider —
# point at an S3-compatible store. Bucket needs a public-read (or signed-URL)
# policy or media previews/publishes break. MinIO is the zero-cloud option.
STORAGE_PROVIDER=aws
# --- AWS S3 (default path) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=montrai-media
# --- Wasabi (STORAGE_PROVIDER=wasabi) ---
WASABI_ACCESS_KEY_ID=
WASABI_SECRET_ACCESS_KEY=
WASABI_REGION=
WASABI_BUCKET_NAME=
WASABI_ENDPOINT=


# -----------------------------------------------------------------------------
# Email — Brevo / Resend / generic SMTP (all OPTIONAL; signup fails soft if unset)
# -----------------------------------------------------------------------------
# Brevo (email verification — fail-soft: a missing key won't block signup):
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@example.com
BREVO_SENDER_NAME=MontrAI
# Resend (transactional):
RESEND_API_KEY=
EMAIL_FROM=noreply@example.com
SMTP_FROM=noreply@example.com
# Generic SMTP path:
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=
# UI gate for the email provider:
NEXT_PUBLIC_EMAIL_PROVIDER_ENABLED=false


# -----------------------------------------------------------------------------
# Observability — Sentry / PostHog / logs / Langfuse (all OPTIONAL; empty = no-op)
# -----------------------------------------------------------------------------
# --- Sentry (leave DSN empty to disable; SDK no-ops) ---
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1            # keep LOW (free perf-unit quota)
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_RELEASE=                          # set in CI from the git SHA
SENTRY_ORG=montrai
SENTRY_PROJECT=montrai-web
# SENTRY_AUTH_TOKEN=                       # build-time only, source-map upload (CI secret)
# Admin /admin/errors server-side proxy to the Sentry issues API:
SENTRY_API_BASE=https://sentry.io/api/0
# SENTRY_API_TOKEN=                        # read-only internal-integration token (server-only)
# --- PostHog (leave key empty to disable; SDK no-ops) ---
# NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# POSTHOG_PERSONAL_API_KEY=                # server-side query API (server-only)
# POSTHOG_PROJECT_ID=
# --- Application log persistence (super-admin /admin/logs) ---
LOG_PERSIST=true
LOG_PERSIST_LEVEL=info                     # min level to persist (debug is too noisy)
LOG_LEVEL=info
LOG_SERVICE_NAME=montrai
# --- Langfuse (optional LLM tracing) ---
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=
# LANGFUSE_BASEURL=
# --- Backup notifications (optional) ---
BACKUP_NOTIFICATION_EMAIL=admin@example.com


# -----------------------------------------------------------------------------
# Per-platform OAuth — BYO-app (Settings -> Connections; all OPTIONAL)
# -----------------------------------------------------------------------------
# In the single-tenant core you register your OWN OAuth apps. Each NEXT_PUBLIC_*
# id is compiled into the client bundle (public); each matching *_SECRET is a
# real secret — leave blank until you create the app. Apollo/Semrush/RevenueCat/
# n8n connect with per-user API keys (no env vars).

# --- X (Twitter) ---
NEXT_PUBLIC_X_CLIENT_ID=
X_CLIENT_SECRET=
X_OAUTH_APP_URL=
X_OAUTH_INCLUDE_MEDIA_WRITE=false
# X_API_TIER=

# --- LinkedIn ---
NEXT_PUBLIC_LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# --- Facebook / Instagram / Threads (Meta) ---
NEXT_PUBLIC_FACEBOOK_APP_ID=
# FACEBOOK_APP_ID=                          # alias of NEXT_PUBLIC_FACEBOOK_APP_ID
FACEBOOK_APP_SECRET=
# META_APP_SECRET=                          # alias of FACEBOOK_APP_SECRET
META_WEBHOOK_VERIFY_TOKEN=
META_LEADS_WEBHOOK_VERIFY_TOKEN=
# META_ADS_GRAPH_VERSION=

# --- Reddit ---
NEXT_PUBLIC_REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# --- Dribbble ---
NEXT_PUBLIC_DRIBBBLE_CLIENT_ID=
DRIBBBLE_CLIENT_SECRET=

# --- Google / YouTube / Google Business / Blogger ---
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_ID=                         # alias of NEXT_PUBLIC_GOOGLE_CLIENT_ID
# YOUTUBE_CLIENT_ID=                        # alias for the YouTube path
GOOGLE_CLIENT_SECRET=
# YOUTUBE_CLIENT_SECRET=                    # alias of GOOGLE_CLIENT_SECRET
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=false

# --- Google Ads (falls back to GOOGLE_CLIENT_ID if unset) ---
# GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
# GOOGLE_ADS_API_VERSION=

# --- Pinterest ---
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=

# --- TikTok ---
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# --- Notion ---
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# --- Slack ---
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# --- Discord ---
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# --- Microsoft ---
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# --- WhatsApp (Meta) ---
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# --- WordPress (App-Passwords path) ---
WORDPRESS_CLIENT_ID=
WORDPRESS_URL=
WORDPRESS_USERNAME=
WORDPRESS_APPLICATION_PASSWORD=

# --- Shopify ---
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# --- Mailchimp ---
MAILCHIMP_CLIENT_ID=
MAILCHIMP_CLIENT_SECRET=

# --- HubSpot ---
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# --- Airtable (PKCE) ---
AIRTABLE_CLIENT_ID=
AIRTABLE_CLIENT_SECRET=

# --- Zoho (multi-DC) ---
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=

# --- Webflow ---
WEBFLOW_CLIENT_ID=
WEBFLOW_CLIENT_SECRET=


# -----------------------------------------------------------------------------
# Voice / telephony (OPTIONAL — "voice" compose profile only)
# -----------------------------------------------------------------------------
# STT/TTS keys reuse DEEPGRAM_API_KEY / ELEVENLABS_API_KEY / VOICE_REALTIME_API_KEY above.
# LIVEKIT_URL=
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# Engine tuning (non-secret):
# VOICE_ENGINE_MODE=
# VOICE_STT_PROVIDER=
# VOICE_TTS_PROVIDER=
# VOICE_TURN_DETECTION=
# VOICE_VAD_MODEL_PATH=
# VOICE_EOU_MODEL_PATH=
# VOICE_REALTIME_MODEL=
# VOICE_REALTIME_VOICE=
# VOICE_LLM_MODEL=
# VOICE_LLM_SYSTEM_PROMPT=
# VOICE_WS_PORT=
# VOICE_CAMPAIGN_CONCURRENCY=
# VOICE_ORG_CONCURRENT_CALL_CAP=
# VOICE_MEDIA_CONNECT_TIMEOUT_MS=


# -----------------------------------------------------------------------------
# Feature flags / misc (OPTIONAL — Mongo-migration flags can be dropped later)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_DUAL_WRITE=false
NEXT_PUBLIC_READ_FROM_MONGO=true

# -----------------------------------------------------------------------------
# Worker tuning (OPTIONAL)
# -----------------------------------------------------------------------------
# WORKFLOW_WORKER_CONCURRENCY=5
# WORKFLOW_POLL_CONCURRENCY=
